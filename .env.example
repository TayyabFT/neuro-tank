# =================================================================
# EmailJS credentials — get these from https://dashboard.emailjs.com/
# (See EMAIL_SETUP.md for the full step-by-step.)
# =================================================================

# Service ID (the Gmail service you connect in EmailJS)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template ID for the NOTIFICATION email (sent to neurotank2.5@gmail.com)
VITE_EMAILJS_ADMIN_TEMPLATE_ID=template_admin_xxxxx

# Template ID for the CONFIRMATION email (sent to the client)
VITE_EMAILJS_CLIENT_TEMPLATE_ID=template_client_xxxxx

# Public key (safe to expose in the browser bundle)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
